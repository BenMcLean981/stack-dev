  "license": "MIT",
  "homepage": "https://github.com/BenMcLean981/stack-dev#readme",
  "repository": "github:BenMcLean981/stack-dev",
  "bin": {
    "stack": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/index.js",
    "check-types": "tsgo --noEmit",
