    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@stack-dev/core": "workspace:*",
    "commander": "catalog:",
    "enquirer": "catalog:",
    "fast-glob": "catalog:",
    "glob": "catalog:",
    "json5": "catalog:",
    "lodash": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@stack-dev/oxlint-config": "workspace:*",
    "@stack-dev/prettier-config": "workspace:*",
    "@stack-dev/typescript-config": "workspace:*",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  }
}