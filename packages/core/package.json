{
  "name": "@stack-dev/core",
  "version": "0.2.1",
  "private": false,
  "license": "MIT",
  "devDependencies": {
    "@stack-dev/oxlint-config": "workspace:*",
    "@stack-dev/prettier-config": "workspace:*",
    "@stack-dev/typescript-config": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "check-types": "tsgo --noEmit",
    "build": "tsdown",
    "lint": "oxlint",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "sideEffects": false
}
