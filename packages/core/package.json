{
  "name": "@stack-dev/core",
  "version": "0.2.1",
  "private": false,
  "license": "MIT",
  "devDependencies": {
    "@stack-dev/eslint-config": "workspace:*",
    "@stack-dev/prettier-config": "workspace:*",
    "@stack-dev/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "tsup",
    "lint": "eslint",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "sideEffects": false
}
